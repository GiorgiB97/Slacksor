# Slack tokens (required)
# Bot User OAuth Token from OAuth & Permissions -> Install App
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token from Socket Mode -> App-Level Tokens (scope: connections:write)
SLACK_APP_TOKEN=xapp-your-app-token-here

# Optional: SQLite DB location (default: ./slacksor.db)
# SLACKSOR_DB_PATH=./slacksor.db

# Optional: timeout in seconds for cursor agent (default: 300)
# SLACKSOR_SESSION_TIMEOUT_SECONDS=300

# Optional: "still working..." post interval (default: 30)
# SLACKSOR_KEEPALIVE_SECONDS=30

# Optional: max Slack message chunk size (default: 3500)
# SLACKSOR_POST_CHUNK_SIZE=3500

# Optional: runtime loop interval in seconds (default: 1.0)
# SLACKSOR_POLLING_INTERVAL_SECONDS=1.0

# Optional: mirror Cursor IDE transcripts to Slack (default: true)
# SLACKSOR_ENABLE_IDE_TRANSCRIPT_MIRROR=true

# Optional: enable hook-based Cursor IDE sync (default: true)
# SLACKSOR_ENABLE_CURSOR_HOOKS_SYNC=true
